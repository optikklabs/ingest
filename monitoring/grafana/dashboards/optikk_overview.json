{
  "annotations": {"list": []},
  "description": "Service-wide health overview — HTTP + gRPC traffic, error ratios, DB/Kafka subsystem summary, Go runtime basics. Start here; drill into subsystem dashboards for root cause.",
  "editable": false,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["optikk", "overview"],
  "templating": {"list": [{"name": "service", "label": "Service", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "definition": "label_values(go_goroutines, job)", "query": "label_values(go_goroutines, job)", "regex": "/optikk-.*/", "includeAll": true, "allValue": ".*", "multi": true, "refresh": 2, "current": {"selected": true, "text": ["All"], "value": ["$__all"]}}]},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "title": "Optikk Overview",
  "uid": "optikk-overview",
  "version": 1,
  "panels": [
    {
      "title": "HTTP req/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_http_requests_total{job=~\"$service\"}[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "HTTP 5xx %",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(optikk_http_requests_total{job=~\"$service\",status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(optikk_http_requests_total{job=~\"$service\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "gRPC calls/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_grpc_started_total{job=~\"$service\"}[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "gRPC non-OK %",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(optikk_grpc_handled_total{job=~\"$service\",code!=\"OK\"}[5m])) / clamp_min(sum(rate(optikk_grpc_handled_total{job=~\"$service\"}[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "Ingest records/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_ingest_records_total{job=~\"$service\",result=\"ok\"}[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Kafka consumer lag",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {"expr": "sum(optikk_kafka_consumer_lag_records{job=~\"$service\"})", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 10000}, {"color": "red", "value": 100000}]}}}
    },
    {
      "title": "HTTP req/s by status class",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (status_class, job) (rate(optikk_http_requests_total{job=~\"$service\"}[1m]))",
          "legendFormat": "{{job}} {{status_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "HTTP p95 by route (top 5)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum by (route, le, job) (rate(optikk_http_request_duration_seconds_bucket{job=~\"$service\"}[5m]))))",
          "legendFormat": "{{job}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "gRPC p99 by method",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (method, le, job) (rate(optikk_grpc_handling_duration_seconds_bucket{job=~\"$service\"}[5m])))",
          "legendFormat": "{{job}} {{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Ingest records/s by signal",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sum by (signal, result, job) (rate(optikk_ingest_records_total{job=~\"$service\"}[1m]))",
          "legendFormat": "{{job}} {{signal}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "DB query rate by system",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "sum by (system, job) (rate(optikk_db_queries_total{job=~\"$service\"}[1m]))",
          "legendFormat": "{{job}} {{system}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Auth denials (5m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "sum by (reason, job) (rate(optikk_auth_denied_total{job=~\"$service\"}[5m]))",
          "legendFormat": "{{job}} {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Go goroutines",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {"expr": "go_goroutines{job=~\"$service\"}", "legendFormat": "{{job}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Go heap in use",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {"expr": "go_memstats_heap_inuse_bytes{job=~\"$service\"}", "legendFormat": "{{job}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
