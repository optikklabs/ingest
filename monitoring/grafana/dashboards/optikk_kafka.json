{
  "annotations": {"list": []},
  "description": "Kafka client health — produce rate & latency by topic, consumer-group lag by partition, rebalances, broker-connect outcomes.",
  "editable": false,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["optikk", "kafka"],
  "templating": {
    "list": [{"name": "service", "label": "Service", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "definition": "label_values(go_goroutines, job)", "query": "label_values(go_goroutines, job)", "regex": "/optikk-.*/", "includeAll": true, "allValue": ".*", "multi": true, "refresh": 2, "current": {"selected": true, "text": ["All"], "value": ["$__all"]}},
      {
        "name": "topic",
        "label": "Topic",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(optikk_kafka_produce_duration_seconds_count, topic)",
        "query": "label_values(optikk_kafka_produce_duration_seconds_count, topic)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "title": "Optikk Kafka",
  "uid": "optikk-kafka",
  "version": 1,
  "panels": [
    {
      "title": "Produce rate by topic",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (topic, job) (rate(optikk_kafka_produce_duration_seconds_count{job=~\"$service\",topic=~\"$topic\"}[1m]))",
          "legendFormat": "{{job}} {{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Produce latency p50 / p99",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (topic, le, job) (rate(optikk_kafka_produce_duration_seconds_bucket{job=~\"$service\",topic=~\"$topic\"}[5m])))",
          "legendFormat": "{{job}} {{topic}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (topic, le, job) (rate(optikk_kafka_produce_duration_seconds_bucket{job=~\"$service\",topic=~\"$topic\"}[5m])))",
          "legendFormat": "{{job}} {{topic}} p99",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Consumer lag (records)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum by (topic, group, job) (optikk_kafka_consumer_lag_records{job=~\"$service\",topic=~\"$topic\"})",
          "legendFormat": "{{job}} {{topic}} / {{group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Per-partition lag",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "optikk_kafka_consumer_lag_records{job=~\"$service\",topic=~\"$topic\"}",
          "legendFormat": "{{job}} {{topic}} p{{partition}} / {{group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Rebalances (5m rate)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "sum(rate(optikk_kafka_rebalances_total{job=~\"$service\"}[5m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Broker connect errors (5m rate)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 16},
      "targets": [
        {"expr": "sum(rate(optikk_kafka_broker_connects_total{job=~\"$service\",result=\"err\"}[5m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}]}}}
    }
  ]
}
